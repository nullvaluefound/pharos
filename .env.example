# --- Required ---
OPENAI_API_KEY=sk-replace-me
JWT_SECRET=please-change-me-to-a-long-random-string

# --- LLM ---
OPENAI_MODEL=o4-mini
# Leave OPENAI_BASE_URL unset to use the default https://api.openai.com/v1.
# Only set it (with full https:// scheme) for Azure / proxies / local LLMs.
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- Storage ---
PHAROS_DB_DIR=./data

# --- Retention ---
ARCHIVE_AFTER_DAYS=45

# --- Constellations (cross-source story clustering) ---
CLUSTER_WINDOW_DAYS=7
CLUSTER_MIN_SHARED=4
CLUSTER_SIM_THRESHOLD=0.55

# --- Lantern (enrichment) ---
LANTERN_BATCH=10
LANTERN_CONCURRENCY=4
LANTERN_POLL_INTERVAL_SEC=10

# --- Ingestion ---
DEFAULT_FEED_POLL_INTERVAL_SEC=14400
HTTP_USER_AGENT=Pharos/0.1 (+https://github.com/your/pharos)

# --- API ---
ALLOW_REGISTRATION=false
CORS_ORIGINS=http://localhost:3000

# --- Logging ---
LOG_LEVEL=INFO
