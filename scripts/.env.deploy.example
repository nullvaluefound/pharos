# --------------------------------------------------------------------
# Pharos -- deploy environment example
# --------------------------------------------------------------------
# Copy these lines into a `.env` file at the REPO ROOT (the same folder
# that contains README.md / LICENSE / pyproject.toml). The repo root
# `.env` is gitignored, so credentials placed there are never committed.
#
#   cp scripts/.env.deploy.example .env
#   # then edit .env with your real values
#
# Required for `python scripts/deploy_do.py`:
#
PHAROS_DO_HOST=your.droplet.ip.or.hostname
PHAROS_DO_USER=root
# Either set a password OR a key path. If both are set, paramiko uses
# the key first and the password as a fallback.
PHAROS_DO_PASSWORD=replace-with-real-password
# PHAROS_DO_KEY=/absolute/path/to/private/key
# --------------------------------------------------------------------
