[Unit]
Description=Pharos API server
After=network.target

[Service]
Type=simple
User=pharos
Group=pharos
WorkingDirectory=/opt/pharos
EnvironmentFile=/etc/pharos/pharos.env
ExecStart=/opt/pharos/venv/bin/uvicorn pharos.api.app:create_app --factory --host 0.0.0.0 --port 8000
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
